{
  "name": "agentic-operator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "gen:v4-snapshot": "node --env-file=.env.local --import tsx scripts/gen-v4-snapshot.ts",
    "simple-rule-check": "node --env-file=.env.local --import tsx scripts/simple-rule-check.ts",
    "simple-rule-check:seed": "node --env-file=.env.local --import tsx scripts/simple-rule-check-seed.ts",
    "simple-rule-check:seed:check": "node --env-file=.env.local --import tsx scripts/simple-rule-check-seed.ts --check-only",
    "rule-check": "node --env-file=.env.local --import tsx scripts/rule-check.ts",
    "rule-check:seed": "npm run simple-rule-check:seed",
    "rule-check:seed:check": "npm run simple-rule-check:seed:check"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "clsx": "^2.1.1",
    "next": "16.2.4",
    "openai": "^6.37.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
