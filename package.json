{
  "name": "agentic-operator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "gen:ontology": "node --env-file=.env.local --import tsx scripts/gen-action-snapshot.ts",
    "gen:ontology:types": "node --import tsx scripts/gen-action-types.ts",
    "verify:ontology": "node --import tsx scripts/verify-snapshots.ts",
    "smoke:ontology": "node --env-file=.env.local --import tsx scripts/smoke-ontology.ts",
    "gen:v4": "node --env-file=.env.local --import tsx scripts/gen-v4-templates.ts",
    "gen:v4-snapshot": "node --env-file=.env.local --import tsx scripts/gen-v4-snapshot.ts",
    "check:v4-drift": "node --env-file=.env.local --import tsx scripts/check-v4-drift.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
